# ===================================================
# 📱 HALAL FORMOSA - ENVIRONMENT CONFIGURATION TEMPLATE
# ===================================================
# Copy this file to '.env' and fill in your actual credentials.
# Do not commit your active '.env' file containing real secrets to Git.

# ---------------------------------------------------
# 🚀 APP CORE
# ---------------------------------------------------
VITE_APP_VERSION=1.0.0

# ---------------------------------------------------
# ⚡ SUPABASE BACKEND SERVICES
# ---------------------------------------------------
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anonymous_public_key

# ---------------------------------------------------
# 🗺️ GOOGLE CLOUD APIS
# ---------------------------------------------------
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_GOOGLE_TRANSLATION_API_KEY=your_google_translation_api_key

# ---------------------------------------------------
# 👁️ INGREDIENTS OCR ENGINE (OPTIONAL)
# ---------------------------------------------------
VITE_OCR_SPACE_API_KEY=your_ocr_space_api_key

# ---------------------------------------------------
# 🔔 PUSH NOTIFICATIONS (ONESIGNAL)
# ---------------------------------------------------
VITE_ONESIGNAL_APP_ID=your_onesignal_app_id

# ---------------------------------------------------
# 💎 IN-APP PURCHASES (REVENUECAT)
# ---------------------------------------------------
VITE_REVENUECAT_API_KEY=your_revenuecat_api_key

# ---------------------------------------------------
# 🔒 GOOGLE RECAPTCHA SECURITY
# ---------------------------------------------------
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
VITE_RECAPTCHA_ENABLED=false

# ---------------------------------------------------
# 🛒 E-COMMERCE SWITCHES
# ---------------------------------------------------
VITE_STORE_UNDER_CONSTRUCTION=false

# ---------------------------------------------------
# 📢 GOOGLE ADMOB ADVERTISING
# ---------------------------------------------------
VITE_ADMOB_TESTING=true

# --- iOS Ad Unit IDs ---
VITE_ADMOB_IOS_SEARCH_BANNER_ID=your_ios_search_banner_id
VITE_ADMOB_IOS_EXPLORE_BANNER_ID=your_ios_explore_banner_id
VITE_ADMOB_IOS_NEWS_BANNER_ID=your_ios_news_banner_id
VITE_ADMOB_IOS_ITEM_DETAILS_BANNER_ID=your_ios_item_details_banner_id
VITE_ADMOB_IOS_SCAN_RESULTS_BANNER_ID=your_ios_scan_results_banner_id
VITE_ADMOB_IOS_TRIP_BANNER_ID=your_ios_trip_banner_id
VITE_ADMOB_IOS_STORE_BANNER_ID=your_ios_store_banner_id
VITE_ADMOB_IOS_STORE_DETAIL_BANNER_ID=your_ios_store_detail_banner_id
VITE_ADMOB_IOS_PLACE_DETAIL_BANNER_ID=your_ios_place_detail_banner_id
VITE_ADMOB_IOS_REWARDED_AD_ID=your_ios_rewarded_ad_id

# --- Android Ad Unit IDs ---
VITE_ADMOB_ANDROID_SEARCH_BANNER_ID=your_android_search_banner_id
VITE_ADMOB_ANDROID_EXPLORE_BANNER_ID=your_android_explore_banner_id
VITE_ADMOB_ANDROID_NEWS_BANNER_ID=your_android_news_banner_id
VITE_ADMOB_ANDROID_ITEM_DETAILS_BANNER_ID=your_android_item_details_banner_id
VITE_ADMOB_ANDROID_SCAN_RESULTS_BANNER_ID=your_android_scan_results_banner_id
VITE_ADMOB_ANDROID_TRIP_BANNER_ID=your_android_trip_banner_id
VITE_ADMOB_ANDROID_STORE_BANNER_ID=your_android_store_banner_id
VITE_ADMOB_ANDROID_STORE_DETAIL_BANNER_ID=your_android_store_detail_banner_id
VITE_ADMOB_ANDROID_PLACE_DETAIL_BANNER_ID=your_android_place_detail_banner_id
VITE_ADMOB_ANDROID_REWARDED_AD_ID=your_android_rewarded_ad_id